{
  "manifest_version": 3,
  "name": "Stickman Live Defense - YouTube Chat Bridge",
  "version": "1.0",
  "description": "유튜브 라이브 채팅을 Stickman Defense 게임으로 전달합니다.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/live_chat*", "https://www.youtube.com/watch*"],
      "js": ["content_youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*"],
      "js": ["content_game.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Stickman Chat Bridge",
    "default_popup": "popup.html"
  }
}
